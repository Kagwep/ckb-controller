{
  "name": "controller-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser demo: CKB controller session + Fiber payment channel (buy troops).",
  "scripts": {
    "sync-wasm": "node scripts/copy-pkg.mjs",
    "predev": "npm run sync-wasm",
    "prebuild": "npm run sync-wasm",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "npm run sync-wasm && tsc --noEmit"
  },
  "dependencies": {
    "@ckb-ccc/core": "^1.15.0",
    "@ckb-controller/sdk": "file:../sdk-js",
    "@nervosnetwork/fiber-js": "^0.9.0-rc7",
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0"
  },
  "devDependencies": {
    "puppeteer-core": "^25.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-node-polyfills": "^0.28.0"
  },
  "comment": "Live mode (in-browser Fiber node) additionally needs: npm i @nervosnetwork/fiber-js"
}
