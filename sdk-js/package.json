  },
  "peerDependenciesMeta": {
    "@nervosnetwork/fiber-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nervosnetwork/fiber-js": "^0.9.0-rc7",
    "typescript": "^5.6.3"
  }
